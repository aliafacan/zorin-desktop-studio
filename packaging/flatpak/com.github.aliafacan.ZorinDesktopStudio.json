{
  "app-id": "com.github.aliafacan.ZorinDesktopStudio",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "com.github.aliafacan.ZorinDesktopStudio",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "cleanup": [
    "*.a",
    "*.la",
    "/include"
  ],
  "modules": [
    {
      "name": "zorin-desktop-studio",
      "buildsystem": "simple",
      "build-commands": [
        "install -d /app/bin",
        "install -d /app/share/zorin-desktop-studio",
        "install -d /app/share/applications",
        "install -d /app/share/metainfo",
        "install -d /app/share/icons/hicolor/scalable/apps",
        "install -m 644 backend.py /app/share/zorin-desktop-studio/backend.py",
        "install -m 644 autostart.py /app/share/zorin-desktop-studio/autostart.py",
        "install -m 644 constants.py /app/share/zorin-desktop-studio/constants.py",
        "install -m 644 desktop_entries.py /app/share/zorin-desktop-studio/desktop_entries.py",
        "install -m 644 desktop_layouts.py /app/share/zorin-desktop-studio/desktop_layouts.py",
        "install -m 644 i18n.py /app/share/zorin-desktop-studio/i18n.py",
        "install -m 644 layout_store.py /app/share/zorin-desktop-studio/layout_store.py",
        "install -m 644 main.py /app/share/zorin-desktop-studio/main.py",
        "install -m 644 preferences.py /app/share/zorin-desktop-studio/preferences.py",
        "install -m 644 theme.py /app/share/zorin-desktop-studio/theme.py",
        "install -m 644 ui.py /app/share/zorin-desktop-studio/ui.py",
        "install -m 644 assets/zorin-desktop-studio.svg /app/share/icons/hicolor/scalable/apps/com.github.aliafacan.ZorinDesktopStudio.svg",
        "install -m 644 packaging/flatpak/com.github.aliafacan.ZorinDesktopStudio.desktop /app/share/applications/com.github.aliafacan.ZorinDesktopStudio.desktop",
        "install -m 644 packaging/flatpak/com.github.aliafacan.ZorinDesktopStudio.metainfo.xml /app/share/metainfo/com.github.aliafacan.ZorinDesktopStudio.metainfo.xml",
        "cat > /app/bin/com.github.aliafacan.ZorinDesktopStudio << 'EOF'\n#!/bin/sh\nexec /usr/bin/python3 /app/share/zorin-desktop-studio/main.py \"$@\"\nEOF",
        "chmod 755 /app/bin/com.github.aliafacan.ZorinDesktopStudio"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../.."
        }
      ]
    }
  ]
}
