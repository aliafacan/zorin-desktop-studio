  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Zorin Desktop Studio</name>
  <summary>Desktop icon tuning and launcher/layout manager for Zorin OS</summary>

  <description>
    <p>
      Zorin Desktop Studio is a GTK application for managing desktop icon behavior on Zorin OS.
      It provides live icon size/spacing tuning, desktop launcher editing, and desktop layout save/restore.
    </p>
    <ul>
      <li>Live preview for icon size and spacing</li>
      <li>Edit existing .desktop launchers from Desktop</li>
      <li>Save and restore desktop icon layouts</li>
      <li>Optional auto-load for a selected layout at login</li>
      <li>Turkish and English UI support</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.github.aliafacan.ZorinDesktopStudio.desktop</launchable>
  <developer id="com.github.aliafacan">
